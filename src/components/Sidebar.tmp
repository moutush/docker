import React, { useState, useCallback, useEffect } from 'react';
import Link from 'next/link';
import { usePathname } from 'next/navigation';

interface NavChild {
  label: string;
  href: string;
  icon?: string;
}

interface NavItem {
  label: string;
  icon: string;
  href?: string;
  badge?: string;
  children?: NavChild[];
  section?: string;
}

export default function Sidebar() {
  const [collapsed, setCollapsed] = useState(false);
  const [mobileOpen, setMobileOpen] = useState(false);
  const [openMenus, setOpenMenus] = useState<Record<string, boolean>>({});
  const [navConfig, setNavConfig] = useState<NavItem[]>([]); // Dynamic fetch logic
  const pathname = usePathname();

  useEffect(() => {
    async function fetchMenu() {
      try {
        const res = await fetch('/api/menu');
        if (res.ok) {
           setNavConfig(await res.json());
        }
      } catch (err) {}
    }
    fetchMenu();
  }, []);

            {/* Sidebar */}
            <aside
                className={`sidebar${collapsed ? " collapsed" : ""}${mobileOpen ? " mobile-open" : ""}`}
                aria-label="Main navigation"
            >
                {/* Header */}
                <div className="sidebar-header">
                    <div className="sidebar-logo-icon">
                        <i className="bi bi-hexagon-fill" />
                    </div>
                    <span className="sidebar-brand-text">AdminPanel</span>
                    <button
                        className="sidebar-collapse-btn ms-auto"
                        onClick={() => setCollapsed(!collapsed)}
                        title={collapsed ? "Expand sidebar" : "Collapse sidebar"}
                    >
                        <i className={`bi ${collapsed ? "bi-chevron-right" : "bi-chevron-left"}`} />
                    </button>
                </div>

                {/* Navigation */}
                <nav className="sidebar-nav">
                    {navConfig.map((item, idx) => {
                        const hasChildren = !!(item.children && item.children.length > 0);
                        const isOpen = openMenus[item.label];
                        const isActive = isActiveParent(item);

                        return (
                            <React.Fragment key={item.label}>
                                {/* Section label */}
                                {item.section && (
                                    <div className="nav-section-label">{item.section}</div>
                                )}

                                <div
                                    className="nav-item-wrapper"
                                    data-tooltip={item.label}
                                >
                                    {/* Parent item */}
                                    {hasChildren ? (
                                        <button
                                            className={`nav-link-item${isActive ? " active" : ""}`}
                                            onClick={() => toggleMenu(item.label)}
                                            aria-expanded={isOpen}
                                        >
                                            <i className={`bi ${item.icon} nav-link-icon`} />
                                            <span className="nav-link-text">{item.label}</span>
                                            {item.badge && !collapsed && (
                                                <span className="nav-badge">{item.badge}</span>
                                            )}
                                            <i
                                                className={`bi bi-chevron-right nav-link-arrow${isOpen ? " open" : ""}`}
                                            />
                                        </button>
                                    ) : (
                                        <Link
                                            href={item.href!}
                                            className={`nav-link-item${isActive ? " active" : ""}`}
                                            onClick={() => setMobileOpen(false)}
                                        >
                                            <i className={`bi ${item.icon} nav-link-icon`} />
                                            <span className="nav-link-text">{item.label}</span>
                                            {item.badge && (
                                                <span className="nav-badge">{item.badge}</span>
                                            )}
                                        </Link>
                                    )}

                                    {/* Children */}
                                    {hasChildren && (
                                        <div className={`child-menu${isOpen && !collapsed ? " open" : ""}`}>
                                            {item.children!.map((child) => (
                                                <Link
                                                    key={child.href}
                                                    href={child.href}
                                                    className={`child-nav-link${isActiveChild(child.href) ? " active" : ""}`}
                                                    onClick={() => setMobileOpen(false)}
                                                >
                                                    {child.label}
                                                </Link>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            </React.Fragment>
                        );
                    })}
                </nav>

                {/* Footer */}
                <div className="sidebar-footer">
                    <div className="user-avatar">JD</div>
                    <div className="user-info">
                        <p className="user-name">John Doe</p>
                        <p className="user-role">Super Admin</p>
                    </div>
                </div>
            </aside>
        </>
    );
}
