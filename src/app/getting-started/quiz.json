                ],
                "description": "An image is an immutable template just like a frozen meal box with instructions and ingredients."
            },
            {
                "level": "foundation",
                "question": "What is the key difference between Virtual Machines and Containers?",
                "type": "radio",
                "options": [
                    { "text": "VMs share the host kernel, while containers abstract hardware.", "answer": false },
                    { "text": "VMs abstract the hardware (Full House), while Containers share the host kernel (Apartment).", "answer": true },
                    { "text": "Containers require a Hypervisor to run.", "answer": false },
                    { "text": "VMs are faster to start up than containers.", "answer": false }
                ],
                "description": "VMs emulate hardware and run a full Guest OS. Containers share the host OS Kernel directly, making them lightweight."
            },
            {
                "level": "foundation",
                "question": "Which of the following is NOT one of the 3 main parts of Docker?",
                "type": "radio",
                "options": [
                    { "text": "The Recipe (Dockerfile)", "answer": false },
                    { "text": "The Frozen Meal (Image)", "answer": false },
                    { "text": "The Hypervisor (VM Manager)", "answer": true },
                    { "text": "The Cooked Meal (Container)", "answer": false }
                ],
                "description": "Hypervisors belong to Virtual Machines. Docker relies on Images, Containers, and Dockerfiles to build apps."
            },
            {
                "level": "foundation",
                "question": "What happens if you try to modify the core ingredients of a built Image directly?",
                "type": "radio",
                "options": [
                    { "text": "The original image updates automatically.", "answer": false },
                    { "text": "Images are read-only (immutable); you must build a new image to change it.", "answer": true },
                    { "text": "The Registry rejects it.", "answer": false },
                    { "text": "The Container crashes.", "answer": false }
                ],
                "description": "Images are frozen in time. To update one, you must build a fresh image with new instructions."
            },
