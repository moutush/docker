                    { "text": "SIGTERM politely asks the app to shut down cleanly, while SIGKILL pulls the power plug instantly.", "answer": true },
                    { "text": "SIGKILL saves data, SIGTERM deletes it.", "answer": false },
                    { "text": "Docker only supports SIGKILL.", "answer": false }
                ],
                "description": "SIGTERM gives the application a short grace period to save its work and close connections securely."
            },
