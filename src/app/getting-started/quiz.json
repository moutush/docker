                    { "text": "It relies on the host machine's specific directory structure and maps it directly into the container.", "answer": true },
                    { "text": "It stores data purely in memory (RAM).", "answer": false },
                    { "text": "It cannot be modified by the container.", "answer": false }
                ],
                "description": "Bind mounts link a specific folder on your Host OS (like ~/my-project) directly into the container, bypassing Docker's volume management."
            },
            {
                "level": "foundation",
                "question": "What is the 'Amnesia Effect' in containers?",
                "type": "radio",
                "options": [
                    { "text": "Containers forget their IP address when stopped.", "answer": false },
                    { "text": "All data written directly inside the container's writable layer is permanently lost when the container is deleted.", "answer": true },
                    { "text": "Containers delete attached volumes upon restart.", "answer": false },
                    { "text": "Nodes forget who the manager is if heartbeats are lost.", "answer": false }
                ],
                "description": "Containers are ephemeral. Any data not saved in a Volume or Bind Mount is wiped clean as soon as the container dies."
            },
            {
                "level": "foundation",
                "question": "Who manages the actual files when using a Docker Volume?",
                "type": "radio",
                "options": [
                    { "text": "The host operating system entirely natively.", "answer": false },
                    { "text": "Docker itself, storing it in a protected internal directory (like /var/lib/docker).", "answer": true },
                    { "text": "The container's internal filesystem directly.", "answer": false },
                    { "text": "A remote cloud provider always.", "answer": false }
                ],
                "description": "Volumes are entirely managed by Docker, providing excellent isolation and backup capabilities."
            },
            {
                "level": "foundation",
                "question": "When should you prefer a Bind Mount over a Volume?",
                "type": "radio",
