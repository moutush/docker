    {
        "node": "Layers & UnionFS",
        "questions": [
            {
                "level": "foundation",
                "question": "What is the UnionFS \"Tax\"?",
                "type": "radio",
                "options": [
                    { "text": "The money you pay for Docker Pro.", "answer": false },
                    { "text": "The performance overhead of merging multiple read-only layers together on disk.", "answer": true },
                    { "text": "The networking overhead of DNS in Docker.", "answer": false },
                    { "text": "The CPU limitation set by cgroups.", "answer": false }
                ],
                "description": "UnionFS dynamically merges layers to look like a single filesystem, which can drastically slow down high I/O operations."
            },
            {
                "level": "foundation",
                "question": "If you delete a large 100MB file in a subsequent RUN layer step, what happens to the final image size?",
                "type": "radio",
                "options": [
                    { "text": "It decreases by 100MB.", "answer": false },
                    { "text": "It decreases by 50MB because of compression.", "answer": false },
                    { "text": "The size remains the same; the file is only visually hidden (masked).", "answer": true },
                    { "text": "The build fails if you delete files from previous layers.", "answer": false }
                ],
                "description": "Layers are immutable. Deleting a file in a later layer simply adds a 'whiteout' marker, masking it but not reclaiming the actual disk space from the lower layer."
            },
            {
                "level": "foundation",
                "question": "Why should you place `apt-get install` commands near the top of a Dockerfile?",
                "type": "radio",
                "options": [
                    { "text": "To make the container boot faster.", "answer": false },
                    { "text": "Because they change rarely, allowing Docker to heavily cache those slow layers.", "answer": true },
