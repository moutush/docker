                ],
                "description": "cgroups limit and meter the resource usage (CPU, RAM, Block I/O) of a container."
            },
            {
                "level": "foundation",
                "question": "What is the golden rule regarding PID 1?",
                "type": "radio",
                "options": [
                    { "text": "PID 1 must always be a bash process.", "answer": false },
                    { "text": "A container's lifecycle is directly tied to PID 1. If PID 1 dies, the container dies.", "answer": true },
                    { "text": "PID 1 is reserved for the root user on the host OS.", "answer": false },
                    { "text": "Only one container can run PID 1 at a time on a host.", "answer": false }
                ],
                "description": "The primary process executed in the container gets PID 1 inside its namespace. When that process exits, the namespace collapses and the container stops."
            },
            {
                "level": "foundation",
                "question": "What is the primary function of Linux Namespaces?",
                "type": "radio",
                "options": [
                    { "text": "To limit how much CPU the container can use.", "answer": false },
                    { "text": "To provide Isolation by acting as \"Magic Blinders\" so the container thinks it has its own private OS.", "answer": true },
                    { "text": "To compress image layers.", "answer": false },
                    { "text": "To manage external hard drives.", "answer": false }
                ],
                "description": "Namespaces split the global OS domains (like Process Trees, Networking, User IDs) so containers cannot see each other."
            },
            {
                "level": "foundation",
                "question": "What is the subtle difference between killing (SIGKILL) and stopping (SIGTERM) a container?",
                "type": "radio",
                "options": [
