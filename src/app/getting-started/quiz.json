                "question": "Why doesn't a container need its own Linux Kernel?",
                "type": "radio",
                "options": [
                    { "text": "Because it uses a Hypervisor instead.", "answer": false },
                    { "text": "Because it writes its own drivers using Node.js.", "answer": false },
                    { "text": "Because it uses the Host OS's Kernel, acting simply as an isolated folder of processes.", "answer": true },
                    { "text": "Because it relies on Docker Hub to simulate one.", "answer": false }
